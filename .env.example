# RealtyAvatar dashboard — environment template.
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign the dashboard's session JWT cookie
JWT_SECRET=

# Widget API key (format ra_wk_<32 hex>) + org it belongs to
REALTYAVATAR_WIDGET_API_KEY=
REALTYAVATAR_ORG_ID=1
NEXT_PUBLIC_WIDGET_API_KEY=
NEXT_PUBLIC_WIDGET_SITE_ID=
NEXT_PUBLIC_ORG_ID=1

# Browser origins allowed to use the widget API key (comma-separated)
WIDGET_ALLOWED_ORIGINS=https://realestatesales.com.au,https://www.realestatesales.com.au

# Public URL of this dashboard deployment
NEXT_PUBLIC_DASHBOARD_URL=https://realtyavatar-dashboard.vercel.app

# AI provider for the widget chat (at least one required in production)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
